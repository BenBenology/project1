# FastAPI server settings.
API_HOST=127.0.0.1
API_PORT=8000
DATABASE_URL=sqlite:///./data/app.db
SEC_USER_AGENT=project1 research app your-email@example.com

# Streamlit app settings.
STREAMLIT_PORT=8501
STREAMLIT_API_BASE_URL=http://127.0.0.1:8000

# Mock task behavior.
MOCK_TASK_DELAY_SECONDS=2

# MCP market-data runtime.
ENABLE_MCP_MARKET_DATA=false
MARKET_DATA_MCP_HOST=127.0.0.1
MARKET_DATA_MCP_PORT=8765
MARKET_DATA_MCP_TIMEOUT_SECONDS=12
